# AI Scribe Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://meet-scribe.netlify.app

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── AWS S3 Storage ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=meet-scribe-storage

# ─── Firebase (for frontend auth — keys are public, safe to commit) ──────────
# These are used by the frontend only, listed here for reference.

# ─── Chrome Profile (EC2 only) ───────────────────────────────────────────────
# On EC2, the Chrome profile persists at /opt/ai-scribe/data/chrome-profile
# No need for GOOGLE_COOKIES — the userDataDir handles authentication natively.
